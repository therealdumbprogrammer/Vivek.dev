---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Vivek.dev`} description={post.data.description}>
  <article class="mx-auto max-w-3xl py-6 sm:py-12">
    <a class="text-sm font-medium text-slate-600 outline-none transition hover:text-blue-700 focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-4" href="/blog">← Back to blog</a>
    <header class="mt-10">
      <time class="text-sm text-slate-500" datetime={post.data.publishDate.toISOString()}>
        {post.data.publishDate.toLocaleDateString('en-US', {
          day: 'numeric',
          month: 'long',
          year: 'numeric',
        })}
      </time>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-balance sm:text-5xl">{post.data.title}</h1>
      <p class="mt-5 text-lg leading-8 text-slate-600">{post.data.description}</p>
    </header>
    <div class="mt-12 text-lg leading-8 text-slate-700 [&_p]:mt-6 [&_p:first-child]:mt-0 [&_a]:font-medium [&_a]:text-blue-700 [&_a]:underline [&_a]:underline-offset-4">
      <Content />
    </div>
  </article>
</BaseLayout>
