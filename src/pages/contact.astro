---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Vivek.dev" description="How to contact Vivek.dev.">
  <section class="max-w-3xl py-6 sm:py-12">
    <p class="text-sm font-semibold tracking-wide text-blue-700 uppercase">Contact</p>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight text-balance sm:text-5xl">Let’s get in touch.</h1>
    <p class="mt-7 text-lg leading-8 text-slate-600">
      Reach out by email or follow my technical content on YouTube.
    </p>
    <dl class="mt-8 space-y-5 text-lg">
      <div>
        <dt class="text-sm font-semibold tracking-wide text-slate-500 uppercase">Email</dt>
        <dd class="mt-1"><a class="font-medium text-blue-700 underline decoration-blue-300 underline-offset-4 transition hover:text-blue-900 focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2" href="mailto:therealdumbprogrammer@gmail.com">therealdumbprogrammer@gmail.com</a></dd>
      </div>
      <div>
        <dt class="text-sm font-semibold tracking-wide text-slate-500 uppercase">YouTube</dt>
        <dd class="mt-1"><a class="font-medium text-blue-700 underline decoration-blue-300 underline-offset-4 transition hover:text-blue-900 focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2" href="https://www.youtube.com/@the_codealchemist" target="_blank" rel="noopener noreferrer">youtube.com/@the_codealchemist</a></dd>
      </div>
    </dl>
  </section>
</BaseLayout>
